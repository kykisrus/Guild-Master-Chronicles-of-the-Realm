[node name="TutBody" type="Label" parent="TutorialPanel/TutVBox"]
layout_mode = 2
text = "1) Рекрутинг — наймите героя
2) Отряды — соберите отряд (2–6)
3) Квесты — отправьте на задание
4) Нажмите «Закончить день» в верхней панели
ГМ создаёт только свой отряд. Смерть ГМ = конец игры."
autowrap_mode = 3

