[sub_resource type="Shader" id="Shader_logo_key"]
code = "shader_type canvas_item;\n\nvoid fragment() {\n\tvec4 source = texture(TEXTURE, UV);\n\tfloat lightness = max(source.r, max(source.g, source.b));\n\tfloat alpha = smoothstep(0.025, 0.095, lightness);\n\tCOLOR = vec4(source.rgb, source.a * alpha);\n}\n"

[sub_resource type="ShaderMaterial" id="ShaderMaterial_logo_key"]
shader = SubResource("Shader_logo_key")

